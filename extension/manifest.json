{
  "manifest_version": 3,
  "name": "Ammit",
  "version": "0.7.2",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "ammit@nolicen.se",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": ["websiteContent", "technicalAndInteraction"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": ["storage", "alarms", "declarativeNetRequest", "scripting"],
  "host_permissions": [
    "https://music.youtube.com/*",
    "https://open.spotify.com/*",
    "https://spclient.wg.spotify.com/*",
    "https://musicbrainz.org/*",
    "https://raw.githubusercontent.com/*",
    "https://gist.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "scripts": ["src/config.js", "src/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["src/heuristics.js", "src/widget.js", "src/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["src/spotify-main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["src/heuristics.js", "src/widget.js", "src/spotify-content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/blocklist.json"],
      "matches": ["https://music.youtube.com/*"]
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_title": "Ammit",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  }
}
