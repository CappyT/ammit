  "verdict_whitelisted": { "message": "whitelisted" },
  "verdict_pending": { "message": "evaluating…" },
  "verdict_disabled": { "message": "paused" },

  "toastSkipped": { "message": "Ammit skipped “$NAME$”", "placeholders": { "name": { "content": "$1" } } },
  "toastDevoured": { "message": "Ammit devoured “$NAME$”", "placeholders": { "name": { "content": "$1" } } },
  "toastSuspect": {
    "message": "“$NAME$” looks AI (score $SCORE$) — confirm from the badge",
